# Copy this to runpod/.env ON THE POD and fill in. Do NOT commit a real token.
#   cp runpod/.env.example runpod/.env  && nano runpod/.env

# HuggingFace token with READ scope.
# Prereq: log in to HF, open https://huggingface.co/black-forest-labs/FLUX.2-dev
# and click "Agree and access repository" (FLUX.2-dev is GATED), THEN create a
# token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# This repo (ComfyUI fork) is cloned onto the pod; custom nodes install via its
# own script/install_custom_nodes.py + custom_nodes.manifest.json.
REPO_URL=https://github.com/xuzihe2020/ComfyUI

# Paths (the RunPod network volume is mounted at /workspace, so everything
# persists across pods). The installer expects the venv at <repo-root>/.venv.
WORKSPACE=/workspace
COMFY=/workspace/ComfyUI
VENV=/workspace/ComfyUI/.venv

# Keep the HuggingFace cache on the big volume, not the small container disk.
HF_HOME=/workspace/.hf_cache

# PyTorch CUDA wheel tag. cu124 is correct for A100 (Ampere) / L40S / RTX 6000 Ada.
# Use cu128 only for Blackwell (RTX 5090).
TORCH_CUDA=cu124

# ComfyUI web port (we tunnel this over SSH to your Mac)
COMFY_PORT=8188
